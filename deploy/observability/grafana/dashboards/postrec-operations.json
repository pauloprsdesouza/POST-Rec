{
  "uid": "postrec-ops",
  "title": "POST-Rec Operations",
  "tags": ["post-rec", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API Scrape Up",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "max(up{job=\"postrec-api\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "HTTP Requests (1h)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "sum(increase(postrec_http_requests_total[1h])) or sum(increase(postrec_http_requests_total{job=\"epilogik-otel-collector\"}[1h]))",
        "refId": "A"
      }]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Worker Scrape Up",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "max(up{job=\"postrec-worker\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Celery Tasks (1h)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "sum(increase(postrec_celery_tasks_total{job=\"postrec-worker\"}[1h])) or sum(increase(postrec_celery_tasks_total{job=\"epilogik-otel-collector\"}[1h]))",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum(rate(postrec_http_requests_total[5m])) by (status)",
        "legendFormat": "status {{status}}",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(postrec_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
        "legendFormat": "{{endpoint}}",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Celery Tasks",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "sum(rate(postrec_celery_tasks_total{job=\"postrec-worker\"}[5m])) by (task, state) or sum(rate(postrec_celery_tasks_total{job=\"epilogik-otel-collector\"}[5m])) by (celery_task, celery_state)",
        "legendFormat": "{{task}}{{celery_task}} {{state}}{{celery_state}}",
        "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "OTEL HTTP (local dev via collector)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "sum(rate(postrec_http_requests_total{job=\"epilogik-otel-collector\"}[5m])) by (http_status_code)",
        "legendFormat": "status {{http_status_code}}",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "POST-Rec Logs (Loki)",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "{container=~\"postrec-(api|worker)\"}",
          "refId": "A"
        },
        {
          "expr": "{service_name=~\".*postrec.*\"}",
          "refId": "B"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending" }
    }
  ]
}
