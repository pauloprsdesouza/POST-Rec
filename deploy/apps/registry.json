{
  "domain": "paulorobertosouza.com.br",
  "apps": {
    "researchly": {
      "title": "Researchly",
      "description": "Research smarter — ideas grounded in real literature",
      "service_host": "postrec-web",
      "service_port": 80,
      "base_path": "/researchly"
    },
    "evolution": {
      "title": "Evolution API",
      "description": "WhatsApp manager — open /evolution/manager/ to pair devices",
      "service_host": "postrec-evolution-api",
      "service_port": 8080,
      "base_path": "/evolution",
      "strip_prefix": true,
      "root_paths": ["/manager", "/assets"]
    },
    "portainer": {
      "title": "Portainer",
      "description": "Docker container management",
      "service_host": "postrec-portainer-proxy",
      "service_port": 80,
      "base_path": "/portainer",
      "root_paths": ["/locales", "/api"]
    },
    "grafana": {
      "title": "Grafana",
      "description": "Metrics, logs, and Researchly operations dashboards",
      "service_host": "postrec-grafana-proxy",
      "service_port": 80,
      "base_path": "/grafana"
    }
  }
}
