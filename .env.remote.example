# Remote homelab stack @ 192.168.10.13 (when server is online).
# Copy to .env when using the portainer-stack on your homelab.

APP_ENV=development
APP_NAME=post-rec

DATABASE_URL=postgresql+psycopg://app:CHANGE_ME@192.168.10.13:5432/epilogik

RABBITMQ_HOST=192.168.10.13
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME
CELERY_BROKER_URL=pyamqp://admin:CHANGE_ME@192.168.10.13:5672//
REDIS_URL=redis://:CHANGE_ME@192.168.10.13:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@192.168.10.13:6379/1

CACHE_ENABLED=true
CACHE_REDIS_DB=2

MINIO_ENDPOINT=192.168.10.13:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_USE_SSL=false
MINIO_BUCKET=postrec-artifacts

GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

OPENALEX_EMAIL=
CROSSREF_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=

AUTH_ENABLED=true
API_INTERNAL_KEY=dev-internal-key
JWT_SECRET=dev-jwt-secret-change-in-production

API_BASE_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:5173

OTEL_ENABLED=false
WHATSAPP_NOTIFICATIONS_ENABLED=false

RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_USE_CELERY_DEFERRED=true

EVOLUTION_API_URL=http://192.168.10.13:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
