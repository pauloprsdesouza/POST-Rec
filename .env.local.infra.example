# Use when POST-Rec app runs on the host (uvicorn/celery/npm) but infra runs in Docker.
#   docker compose up -d postgres redis rabbitmq minio minio-init
#   copy .env.local.infra.example .env

APP_ENV=development
APP_NAME=post-rec

DATABASE_URL=postgresql+psycopg://postrec:postrec@localhost:5432/postrec

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=postrec
RABBITMQ_PASSWORD=postrec
CELERY_BROKER_URL=pyamqp://postrec:postrec@localhost:5672//
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

CACHE_ENABLED=true
CACHE_REDIS_DB=2

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=postrec-artifacts

GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

OPENALEX_EMAIL=
CROSSREF_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=

AUTH_ENABLED=true
API_INTERNAL_KEY=dev-internal-key
JWT_SECRET=dev-jwt-secret-change-in-production

API_BASE_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:5173

OTEL_ENABLED=true
WHATSAPP_NOTIFICATIONS_ENABLED=true

RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_USE_CELERY_DEFERRED=true

EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=dev-evolution-api-key
EVOLUTION_INSTANCE_NAME=postrec

# Blind A/B study — SOTA (control) vs FGGV (treatment). See docs/fggv-evaluation.md §6
EXPERIMENT_FGGV_VS_SOTA_ENABLED=true
EXPERIMENT_FGGV_VS_SOTA_ID=fggv_vs_sota_v1
EXPERIMENT_TREATMENT_FRACTION=0.5