# Production environment for Hostinger deployment.
# Copy to .env on the server and fill secrets before `docker compose up`.

APP_ENV=production
APP_NAME=researchly

# --- URLs (set DEPLOY_DOMAIN; publish_hostinger.py derives API/frontend URLs) ---
DEPLOY_DOMAIN=your-domain.example.com
LETSENCRYPT_EMAIL=admin@your-domain.example.com
API_BASE_URL=https://your-domain.example.com/researchly
FRONTEND_APP_URL=https://your-domain.example.com/researchly
GRAFANA_ROOT_URL=https://your-domain.example.com/grafana/
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_ADMIN_USER=admin
PORTAINER_ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH
METRICS_TOKEN=CHANGE_ME_GENERATE_RANDOM_64_CHARS
EVOLUTION_CORS_ORIGIN=https://your-domain.example.com

# --- Generated on deploy — change before going live ---
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# --- Required for LLM features (hostinger_deploy.py reads this from local .env) ---
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

OPENALEX_EMAIL=
# Required for search endpoints (free at https://openalex.org/settings/api).
# Without a key, OpenAlex returns 503 on /works?search= and /topics?search=.
OPENALEX_API_KEY=

CROSSREF_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=

AUTH_ENABLED=true
ADMIN_BOOTSTRAP_EMAILS=admin@example.com

# Docker Compose service hostnames (do not change unless you rename services)
DATABASE_URL=postgresql+psycopg://researchly:postrec@postgres:5432/researchly
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=postrec
RABBITMQ_PASSWORD=postrec
CELERY_BROKER_URL=pyamqp://researchly:postrec@rabbitmq:5672//
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_ENABLED=true
CACHE_REDIS_DB=2
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=postrec-artifacts

EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY
EVOLUTION_INSTANCE_NAME=postrec
WHATSAPP_NOTIFICATIONS_ENABLED=true

# SMTP (OTP via email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@paulorobertosouza.com.br

OTP_LENGTH=6
OTP_TTL_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_USE_CELERY_DEFERRED=true
OTEL_ENABLED=false

QUALIS_ENABLED=true
QUALIS_CSV_PATH=qualis_avaliacoes-2021-2024.csv
QUALIS_BOOST_WEIGHT=0.10
QUALIS_USE_REDIS_CACHE=true
QUALIS_CACHE_TTL=2592000

EXPERIMENT_FGGV_VS_SOTA_ID=fggv_vs_sota_v1
EXPERIMENT_TREATMENT_FRACTION=0.5
