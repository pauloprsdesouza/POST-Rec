# Evolution API stack (used by docker-compose evolution-* services).
# Defaults match POST-Rec .env.local.infra.example / .env.docker.example.

POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=evolution

SERVER_URL=http://localhost:8080
AUTHENTICATION_API_KEY=dev-evolution-api-key

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@evolution-postgres:5432/evolution?schema=evolution_api

CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution

LOG_LEVEL=ERROR,WARN,INFO
LANGUAGE=en
