# Copy to .env when running the full stack with Docker Compose (api/worker/web in containers).
# Merge with your secrets: GEMINI_API_KEY, JWT_SECRET, etc.

APP_ENV=development
APP_NAME=post-rec

DATABASE_URL=postgresql+psycopg://postrec:postrec@postgres:5432/postrec

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=postrec
RABBITMQ_PASSWORD=postrec
CELERY_BROKER_URL=pyamqp://postrec:postrec@rabbitmq:5672//
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

CACHE_ENABLED=true
CACHE_REDIS_DB=2

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=postrec-artifacts

GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

OPENALEX_EMAIL=
CROSSREF_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=

AUTH_ENABLED=true
JWT_SECRET=dev-jwt-secret-change-in-production
ADMIN_BOOTSTRAP_EMAILS=paulo.prsdesouza@gmail.com

API_BASE_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:5173

OTEL_ENABLED=false
WHATSAPP_NOTIFICATIONS_ENABLED=true

# Evolution API — api/worker reach evolution-api:8080 via docker-compose overrides
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=dev-evolution-api-key
EVOLUTION_INSTANCE_NAME=postrec

OTP_LENGTH=6
OTP_TTL_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_USE_CELERY_DEFERRED=true

# Blind A/B study — SOTA (control) vs FGGV (treatment) on Auto mode. See docs/fggv-evaluation.md §6
EXPERIMENT_FGGV_VS_SOTA_ID=fggv_vs_sota_v1
EXPERIMENT_TREATMENT_FRACTION=0.5
