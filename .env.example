APP_ENV=development
APP_NAME=post-rec

# POST-Rec environment
#
# Local Docker (homelab offline):
#   copy .env.local.infra.example .env     — infra in Docker, app on host
#   copy .env.docker.example .env          — full stack in Docker
#   .\scripts\docker_bootstrap.ps1
#
# Remote homelab (legacy):
#   use the 192.168.10.13 values below

APP_ENV=development
APP_NAME=post-rec

# --- Local Docker defaults (see .env.local.infra.example) ---
# DATABASE_URL=postgresql+psycopg://postrec:postrec@localhost:5432/postrec
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=pyamqp://postrec:postrec@localhost:5672//

# --- Homelab stack (portainer-stack @ 192.168.10.13) ---
DATABASE_URL=postgresql+psycopg://app:CHANGE_ME@192.168.10.13:5432/epilogik

RABBITMQ_HOST=192.168.10.13
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME
CELERY_BROKER_URL=pyamqp://admin:CHANGE_ME@192.168.10.13:5672//

REDIS_URL=redis://:CHANGE_ME@192.168.10.13:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@192.168.10.13:6379/1

# App cache (DB 2) — historical / slow-changing reads
CACHE_ENABLED=true
CACHE_REDIS_DB=2

MINIO_ENDPOINT=192.168.10.13:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME
MINIO_USE_SSL=false
MINIO_BUCKET=postrec-artifacts

# Google Gemini — configure via environment variables
GEMINI_API_KEY=
GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

OPENALEX_EMAIL=
CROSSREF_EMAIL=
SEMANTIC_SCHOLAR_API_KEY=
CORE_API_KEY=
CORE_API_BASE_URL=https://api.core.ac.uk/v3

MAX_PAPERS_DEFAULT=50
MAX_RECOMMENDATIONS_DEFAULT=5
RUN_TIMEOUT_SECONDS=900
MAX_COST_PER_RUN_USD=2.00

LOG_LEVEL=INFO
LOG_FORMAT=json

OTEL_SERVICE_NAME=postrec-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.10.13:12345
OTEL_ENABLED=false

RETRIEVAL_FETCH_MAX_ATTEMPTS=5
RETRIEVAL_HTTP_RETRIES=4
RETRIEVAL_MIN_RELEVANCE_SCORE=0.22
RETRIEVAL_USE_CELERY_DEFERRED=true
RETRIEVAL_DEFERRED_TIMEOUT_SECONDS=180
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=21600
RETRIEVAL_CIRCUIT_FAILURE_THRESHOLD=4
RETRIEVAL_CIRCUIT_COOLDOWN_SECONDS=120
RETRIEVAL_MIN_PAPERS_BEFORE_SKIP=12
RETRIEVAL_OPENALEX_MIN_INTERVAL=0.35
RETRIEVAL_CROSSREF_MIN_INTERVAL=0.35
RETRIEVAL_SEMANTIC_SCHOLAR_MIN_INTERVAL=5.0
RETRIEVAL_ARXIV_MIN_INTERVAL=4.0
RETRIEVAL_CORE_MIN_INTERVAL=10.0
RETRIEVAL_CONSOLIDATED_PLAN_ENABLED=true
RETRIEVAL_CORPUS_PREFETCH_ENABLED=true
RETRIEVAL_S2_RECOMMENDATIONS_ENABLED=true
RETRIEVAL_S2_RECOMMENDATION_SEEDS=5
RETRIEVAL_S2_RECOMMENDATION_LIMIT=50
RETRIEVAL_LEARNED_TOPIC_CAP=2
RETRIEVAL_CROSSREF_MAX_QUERIES=2
RETRIEVAL_CORE_MAX_QUERIES=2
RETRIEVAL_OPENALEX_PER_PAGE_MAX=100
RETRIEVAL_CROSSREF_ROWS_MAX=80
RETRIEVAL_SEMANTIC_SCHOLAR_LIMIT_MAX=100
RETRIEVAL_CORE_LIMIT_MAX=100
RETRIEVAL_ARXIV_MAX_RESULTS=40

# Qualis (CAPES Sucupira) journal quality boost during ranking
# Data lives in Postgres (qualis_journal); seed via scripts/seed_qualis.py
QUALIS_ENABLED=true
QUALIS_CSV_PATH=qualis_avaliacoes-2021-2024.csv
QUALIS_BOOST_WEIGHT=0.10
QUALIS_USE_REDIS_CACHE=true
QUALIS_CACHE_TTL=2592000

AUTH_ENABLED=true
API_INTERNAL_KEY=dev-internal-key
JWT_SECRET=dev-jwt-secret-change-in-production

API_BASE_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:5173

# Evolution API (WhatsApp) — local Docker stack or homelab @ 192.168.10.13:8080
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=dev-evolution-api-key
EVOLUTION_INSTANCE_NAME=postrec

PHONE_DEFAULT_COUNTRY_CODE=55

OTP_LENGTH=6
OTP_TTL_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
WHATSAPP_NOTIFICATIONS_ENABLED=true

# Blind A/B study — SOTA (control) vs FGGV (treatment). See docs/fggv-evaluation.md §6
# Set ENABLED=false to disable assignment (users always get their chosen run mode).
EXPERIMENT_FGGV_VS_SOTA_ENABLED=false
EXPERIMENT_FGGV_VS_SOTA_ID=fggv_vs_sota_v1
EXPERIMENT_TREATMENT_FRACTION=0.5
